{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "saykocraft-launcher",
  "version": "0.1.0-beta",
  "identifier": "com.saykocraft.launcher",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SayKOCraft Launcher",
        "width": 512,
        "height": 640,
        "minWidth": 512,
        "minHeight": 600,
        "decorations": false,
        "maximizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
